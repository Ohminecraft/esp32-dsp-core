{
  "name": "dsp-control-app",
  "version": "1.0.0",
  "description": "ESP32 DSP Core Control Application — Professional DSP tuning tool",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "package": "electron-packager . \"ESP32 DSP Control\" --platform=win32 --arch=x64 --out=dist --overwrite"
  },
  "dependencies": {
    "serialport": "^12.0.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^26.8.1",
    "electron-packager": "^17.1.2"
  },
  "author": "ESP32 DSP Core",
  "license": "MIT",
  "build": {
    "appId": "com.esp32.dspcontrol",
    "productName": "ESP32 DSP Control",
    "win": {
      "target": "portable"
    },
    "directories": {
      "output": "dist"
    }
  }
}
